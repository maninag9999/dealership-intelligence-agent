# ==========================================================
# Dealership Intelligence Agent — Environment Variables
# ==========================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit real credentials.

# --- Local Services ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dealership
POSTGRES_USER=dealership_user
POSTGRES_PASSWORD=change_me_locally

# DuckDB — path only, no auth
DUCKDB_PATH=./data/processed/dealership.duckdb

# --- Ollama (local LLM, used Week 3) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# --- ChromaDB (local vector store, used Week 3) ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=dealership_reviews

# --- MLflow (local tracking, used Week 2) ---
MLFLOW_TRACKING_URI=file:./mlruns

# --- FastAPI (used Week 2) ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- Scraping (DealerRater) — no keys, but respect rate limits ---
SCRAPER_USER_AGENT=Portfolio-Project-Bot/1.0 (educational use)
SCRAPER_DELAY_SECONDS=3
SCRAPER_MAX_PAGES=50

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
GROQ_API_KEY=your_groq_api_key_here
